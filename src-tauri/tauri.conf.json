{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mekuri",
  "version": "0.1.0",
  "identifier": "com.mekuri.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mekuri",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU1OEMxMkM0NkE2ODlFNjcKUldSbm5taHF4QktNVlF2RUpCZHFnYU0xanIrS2xJOURJK0FHUWc2TXNhSUVVTUsrVVlNUDh2QmMK",
      "endpoints": [
        "https://github.com/piro0919/mekuri/releases/latest/download/latest.json"
      ]
    }
  }
}
