{
  "name": "mekuri",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "release": "pnpm release:create && pnpm release:upload",
    "release:create": "gh release create v$npm_package_version -t \"Release v$npm_package_version\" --generate-notes",
    "release:generate-latest": "node -e \"const fs=require('fs');const v=process.env.npm_package_version;const sig=fs.readFileSync('src-tauri/target/release/bundle/macos/Mekuri.app.tar.gz.sig','utf8').trim();const json={version:v,notes:'',pub_date:new Date().toISOString(),platforms:{'darwin-aarch64':{signature:sig,url:'https://github.com/piro0919/mekuri/releases/download/v'+v+'/Mekuri.app.tar.gz'}}};fs.writeFileSync('latest.json',JSON.stringify(json,null,2))\"",
    "release:upload": "pnpm release:generate-latest && gh release upload v$npm_package_version \"src-tauri/target/release/bundle/dmg/Mekuri_${npm_package_version}_aarch64.dmg\" \"src-tauri/target/release/bundle/macos/Mekuri.app.tar.gz\" \"src-tauri/target/release/bundle/macos/Mekuri.app.tar.gz.sig\" latest.json --clobber"
  },
  "packageManager": "pnpm@10.27.0",
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}